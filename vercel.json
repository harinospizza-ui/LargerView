{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "harinos-website-main/harinos-website-main/dist",
  "cleanUrls": true,
  "routes": [
    { "src": "/api/auth/login", "dest": "/api/auth.ts" },
    { "src": "/api/auth/change-password", "dest": "/api/auth.ts" },
    { "src": "/api/orders/([^/]+)/status", "dest": "/api/orders.ts?orderId=$1&action=status" },
    { "src": "/api/orders/([^/]+)", "dest": "/api/orders.ts?orderId=$1" },
    { "src": "/api/orders", "dest": "/api/orders.ts" },
    { "src": "/api/customers/([^/]+)/verify", "dest": "/api/customers.ts?customerId=$1&action=verify" },
    { "src": "/api/customers", "dest": "/api/customers.ts" },
    { "src": "/api/wallet/transactions", "dest": "/api/wallet.ts" },
    { "src": "/api/menu-items/seed", "dest": "/api/menu-items.ts?action=seed" },
    { "src": "/api/menu-items", "dest": "/api/menu-items.ts" },
    { "src": "/api/outlets/seed", "dest": "/api/outlets.ts?action=seed" },
    { "src": "/api/outlets", "dest": "/api/outlets.ts" },
    { "src": "/api/offers/seed", "dest": "/api/offers.ts?action=seed" },
    { "src": "/api/offers", "dest": "/api/offers.ts" },
    { "src": "/api/notifications/token", "dest": "/api/notifications.ts" }
  ]
}
